# Realtime assistant configuration (template).
#
# install.sh copies this to the active config path (chmod 600) on first install:
#   user-level:   ~/.config/realtime-assistant/assistant.env
#   system-level: /etc/realtime-assistant/assistant.env
#
# Fill in real values THERE, not here — keep secrets out of git. These are the
# assistant's native environment variables; the systemd unit loads this file via
# EnvironmentFile= and runs the binary with no flags.

# ---- Primary endpoint (tried first) ----
# Use ws:// (or wss://). The realtime path is /v1/realtime.
OPENAI_WS_BASE_URL=ws://PRIMARY-HOST:PORT/v1/realtime
ASSISTANT_MODEL=gpt-realtime
OPENAI_API_KEY=sk-xxx

# ---- Fallback endpoint (used when the primary is unreachable) ----
# Defaults to a LocalAI running on this same host. Leaving FALLBACK_MODEL /
# FALLBACK_API_KEY empty reuses the primary's model / key.
FALLBACK_WS_BASE_URL=ws://localhost:8080/v1/realtime
FALLBACK_MODEL=
FALLBACK_API_KEY=

# ---- Session settings ----
# Input language as ISO-639-1 (e.g. en, it). Empty = server auto-detect.
ASSISTANT_LANGUAGE=
# TTS voice; empty = server default.
ASSISTANT_VOICE=
# System instructions; empty = the binary's built-in default.
ASSISTANT_INSTRUCTIONS=

# ---- Acoustic echo cancellation ----
# Only active when a LocalVQE model was bundled into the binary (built with
# `make`); a plain `go build` leaves AEC off regardless. Hardware speakerphones
# (e.g. Jabra SPEAK) do their own AEC, so this can stay off.
AEC=true
AEC_DELAY_MS=50
